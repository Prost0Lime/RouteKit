<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Режим"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbDirect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Direct" />

            <RadioButton
                android:id="@+id/rbZapret"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zapret" />

            <RadioButton
                android:id="@+id/rbVpn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VPN (активный VLESS-профиль)" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/layoutStrategies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TCP стратегия" />

            <Spinner
                android:id="@+id/spinnerTcp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="UDP/QUIC стратегия" />

            <Spinner
                android:id="@+id/spinnerUdp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="STUN стратегия" />

            <Spinner
                android:id="@+id/spinnerStun"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Домены, по одному на строку">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDomains"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:minLines="6" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvCoverage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnValidateDomains"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Проверить домены" />

            <Button
                android:id="@+id/btnShowDiagnostics"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Диагностика" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
